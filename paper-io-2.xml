<?xml version="1.0" encoding="UTF-8" ?>
<Module>
<ModulePrefs title="google.com" />
<Content type="html"><![CDATA[

<html>
  <head>
    <meta charset="utf-8" />
    <meta name="theme-color" content="#2d3331" />
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no" />
